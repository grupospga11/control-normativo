# Copia este archivo como .env y rellena tus credenciales de Supabase
# NUNCA subas .env a git

# 1. Crea un proyecto gratis en https://supabase.com
# 2. Ve a Project Settings → API y copia la URL y la anon key
# 3. En el editor SQL de Supabase ejecuta:
#
#   CREATE TABLE kv_store (
#     key TEXT PRIMARY KEY,
#     value JSONB NOT NULL,
#     updated_at TIMESTAMPTZ DEFAULT NOW()
#   );
#   ALTER TABLE kv_store ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "public_access" ON kv_store FOR ALL USING (true) WITH CHECK (true);

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
